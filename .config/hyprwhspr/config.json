{
  "$schema": "https://raw.githubusercontent.com/goodroot/hyprwhspr/main/share/config.schema.json",
  "primary_shortcut": "ALT+SHIFT+D",
  "recording_mode": "auto",
  "use_hypr_bindings": true,
  "keyboard_device_names": [
    "HOLTEK USB-HID Keyboard"
  ],
  "model": "base.en",
  "paste_mode": "ctrl_shift",
  "shift_paste": true,
  "transcription_backend": "onnx-asr",
  "audio_feedback": true,
  "start_sound_volume": 0.5,
  "stop_sound_volume": 0.5,
  "start_sound_path": "ping-up.ogg",
  "stop_sound_path": "ping-down.ogg",
  "threads": 4
}